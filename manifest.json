{
  "manifest_version": 3,
  "name": "Deeting Browser Agent",
  "version": "0.1.2",
  "minimum_chrome_version": "116",
  "description": "Bounded browser executor for Deeting desktop-local AI decisions.",
  "icons": {
    "16": "assets/icon.png",
    "32": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "dist/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "dist/content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Deeting Browser Agent",
    "default_popup": "dist/popup.html",
    "default_icon": {
      "16": "assets/icon.png",
      "32": "assets/icon.png"
    }
  },
  "options_page": "dist/options.html"
}
